# Copy to .env and fill in before `docker compose up -d`.
# These feed both docker-compose and the server container.

# ---- public-facing ----
# The public URL Slate is served at (used for CORS + baked into the frontend
# build as VITE_APP_SYNC_SERVER / VITE_APP_WS_SERVER_URL). A reverse proxy
# (e.g. Caddy) routes /api/* and /socket.io/* to the server, the rest to the
# frontend container — so one origin serves everything.
PUBLIC_URL=https://slate.example.com

# Host ports (bound to 127.0.0.1; put the reverse proxy in front).
SERVER_PORT=3030
FRONTEND_PORT=3031

# Clerk publishable key, baked into the frontend build (safe to be public).
VITE_APP_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ---- secrets (CHANGE THESE) ----
# Signs the public-link scoped tokens. Use: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# ---- Postgres ----
POSTGRES_USER=excalidraw
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=excalidraw

# ---- MinIO (S3-compatible file store; data persisted to ./data/minio) ----
MINIO_ROOT_USER=change-me-access-key
MINIO_ROOT_PASSWORD=change-me-secret-key
S3_BUCKET=excalidraw-files
S3_REGION=auto

# ---- bruteforce protection (public link+password path) ----
MAX_FAILED_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ---- auth (Clerk identity) ----
AUTH_DEV_BYPASS=false
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# Optional, only for future server-side Clerk API calls
CLERK_SECRET_KEY=

# ---- using Cloudflare R2 instead of bundled MinIO? ----
# Drop the minio + minio-init services, remove S3_ENDPOINT override in
# docker-compose (point it at your R2 endpoint), and set in the server env:
#   S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   S3_FORCE_PATH_STYLE=false
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY = R2 token pair
