{
  "name": "excalidraw-sync-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sync + realtime + project auth backend for Excalidraw (Postgres + R2)",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "migrate": "bun src/migrate.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
