# Slate frontend — build the Vite app, serve the static bundle with nginx.
# VITE_APP_* are inlined at build time, so they come in as build args.
FROM node:22-alpine AS build
WORKDIR /app

COPY . .
RUN yarn install --frozen-lockfile

ARG VITE_APP_SYNC_SERVER
ARG VITE_APP_WS_SERVER_URL
ARG VITE_APP_CLERK_PUBLISHABLE_KEY
ENV VITE_APP_SYNC_SERVER=$VITE_APP_SYNC_SERVER \
    VITE_APP_WS_SERVER_URL=$VITE_APP_WS_SERVER_URL \
    VITE_APP_CLERK_PUBLISHABLE_KEY=$VITE_APP_CLERK_PUBLISHABLE_KEY \
    NODE_OPTIONS=--max-old-space-size=2560

RUN yarn build:app:docker

FROM nginx:alpine
COPY --from=build /app/excalidraw-app/build /usr/share/nginx/html
COPY excalidraw-app/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
